APP_ENV=local
API_TOKEN=replace-with-local-dev-token
DATABASE_URL=postgresql+psycopg://video:video@postgres:5432/video_editor
REDIS_URL=redis://redis:6379/0
RENDER_QUEUE_BACKEND=rq
PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/projects/{project_id}/connect-drive/callback
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly
GOOGLE_DRIVE_OUTPUT_FOLDER_ID=
TOKEN_ENCRYPTION_KEY=
MALWARE_SCANNER_BACKEND=clamav
ANALYSIS_PROVIDER=deterministic_local
ANALYSIS_PROVIDER_URL=
ANALYSIS_PROVIDER_HEALTH_URL=
ANALYSIS_PROVIDER_TOKEN=
ANALYSIS_PROVIDER_MAX_ATTEMPTS=2
ANALYSIS_PROVIDER_RETRY_BACKOFF_SECONDS=0.25
ANALYSIS_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
ANALYSIS_PROVIDER_CIRCUIT_RESET_SECONDS=60
ANALYSIS_PROVIDER_INCLUDE_PRIVATE_LOCATOR=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=ai-video-editor/outputs
OUTPUT_STORAGE_PROVIDER=drive
AUTO_DELIVER_OUTPUTS=false
CLEANUP_STAGED_OUTPUTS_AFTER_DELIVERY=false
DELIVERED_OUTPUT_RETENTION_DAYS=30
DELIVERED_OUTPUT_RETENTION_POLICY=manual_upload_private_output
OUTPUT_DELIVERY_LOCAL_ROOT=/tmp/ai-video-editor/outputs
LOCAL_PRIVATE_DELIVERY_ROOT=/tmp/ai-video-editor/delivered
MEDIA_ENCRYPTION_KMS_KEY_ID=
REQUIRE_EMBEDDED_SUBTITLES=false
FAIL_ON_BLACK_FRAMES=false

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

N8N_ENCRYPTION_KEY=replace-with-32-plus-chars
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-long-password
